EMAIL_USER=bhalsejyoti140@gmail.com
EMAIL_PASSWORD=bbfhrxfhhybfuzqb
EEMAIL_FROM=API Vendor <bhalsejyoti140@gmail.com>

# Automated low-stock notification scheduler.
# Set interval to 0 to disable the backend cron-like worker.
