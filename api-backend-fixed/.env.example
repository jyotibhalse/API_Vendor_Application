# Remote Postgres over Tailscale.
# Leave DATABASE_URL empty so the app builds the connection string from POSTGRES_*.
DATABASE_URL=

# Use your database host, Tailscale IP, or MagicDNS name here.

POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=api_vendor

# Optional Redis pub/sub for live KOT order push across processes/devices.
REDIS_URL=redis://localhost:6379/0

# JWT / auth
SECRET_KEY=replace_with_a_long_random_secret
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace_with_secure_password
ADMIN_NOTIFICATION_EMAIL=admin@example.com
DEFAULT_PLATFORM_COMMISSION_RATE=8
DEFAULT_PLATFORM_FLAT_FEE=0

# Optional email settings for forgot-password OTP
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password
EMAIL_FROM=API Vendor <your_email@example.com>
MAX_UPLOAD_SIZE_MB=5

# Automated low-stock notification scheduler.
# Set interval to 0 to disable the backend cron-like worker.
LOW_STOCK_NOTIFICATION_INTERVAL_MINUTES=60
LOW_STOCK_NOTIFICATION_REPEAT_HOURS=24
LOW_STOCK_NOTIFICATION_STARTUP_DELAY_SECONDS=15


CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
